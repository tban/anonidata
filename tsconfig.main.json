{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/main/**/*", "src/preload/**/*"]
}
