{
  "name": "anonidata",
  "productName": "Anonidata",
  "version": "1.0.3",
  "description": "Aplicación de escritorio para anonimización de PDFs conforme a RGPD",
  "author": "AnoniData",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tban/anonidata.git"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npx tauri dev",
    "dev:renderer": "vite",
    "build": "npx tauri build",
    "build:renderer": "vite build",
    "build:backend": "./scripts/build-backend.sh",
    "test": "vitest",
    "test:backend": "cd backend && pytest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "tauri": "tauri",
    "release": "node build.js"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "pdfjs-dist": "^5.4.449"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.3.8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.0.4",
    "zustand": "^4.4.7"
  }
}
