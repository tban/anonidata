{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the AnoniData application",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "opener:default",
    "os:default",
    "store:default",
    "updater:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/**/*",
        "$DESKTOP/**/*",
        "$DOCUMENT/**/*",
        "$DOWNLOAD/**/*",
        "**/*",
        "**"
      ]
    },
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "anonidata-backend",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "anonidata-backend",
          "sidecar": true
        }
      ]
    }
  ]
}
